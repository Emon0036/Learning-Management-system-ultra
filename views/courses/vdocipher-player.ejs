<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title || 'Protected video' %></title>
    <style>
      html,
      body {
        width: 100%;
        height: 100%;
        margin: 0;
        overflow: hidden;
        background: #050b12;
      }

      .vdocipher-frame {
        position: relative;
        width: 100%;
        height: 100%;
        background: #050b12;
      }

      .vdocipher-frame iframe {
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
      }

      .vdocipher-watermark {
        position: absolute;
        top: 70%;
        left: 70%;
        z-index: 2;
        max-width: 78%;
        padding: 0.35rem 0.55rem;
        border-radius: 6px;
        color: rgba(255, 255, 255, 0.82);
        background: rgba(0, 0, 0, 0.34);
        font: 500 clamp(0.68rem, 1.4vw, 0.88rem) / 1.25 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        pointer-events: none;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
        transform: translate(-50%, -50%);
        transition: top 1.2s ease, left 1.2s ease, transform 1.2s ease;
      }
    </style>
  </head>
  <body>
    <div class="vdocipher-frame">
      <iframe
        src="<%= playerUrl %>"
        title="<%= title || 'Protected video' %>"
        allow="encrypted-media; fullscreen; picture-in-picture"
        allowfullscreen
      ></iframe>
      <% if (watermarkText) { %>
        <span class="vdocipher-watermark" data-watermark><%= watermarkText %></span>
      <% } %>
    </div>

    <script>
      (() => {
        const watermark = document.querySelector('[data-watermark]');
        if (!watermark) return;

        const baseText = watermark.textContent.trim();

        function updateWatermark() {
          watermark.textContent = `${baseText} | ${new Date().toLocaleString()}`;
        }

        function moveWatermark() {
          const top = 18 + Math.random() * 64;
          const left = 18 + Math.random() * 64;
          const rotation = -10 + Math.random() * 20;
          watermark.style.top = `${top}%`;
          watermark.style.left = `${left}%`;
          watermark.style.transform = `translate(-50%, -50%) rotate(${rotation.toFixed(1)}deg)`;
        }

        updateWatermark();
        moveWatermark();
        window.setInterval(updateWatermark, 30000);
        window.setInterval(moveWatermark, 9000);
      })();
    </script>
  </body>
</html>
